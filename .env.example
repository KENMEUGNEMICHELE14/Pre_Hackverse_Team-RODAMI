# Backend (Spring Boot)
DATABASE_URL=jdbc:postgresql://localhost:5432/antiproc_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — use a strong 256-bit secret in production
JWT_SECRET=my-very-long-256-bit-secret-key-for-hackverse-antiproc-app-2026
JWT_EXPIRATION_MS=86400000

# BCrypt rounds (12 recommended for production)
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
